import java.util.Scanner;

public class MiniECommerceSystem {
    private static String[] catalog = {"Laptop", "Phone", "Headphones"};
    private static int[] stock = {5, 10, 25};

    // Functional Decomposition
    public static void viewCatalog() {
        System.out.println("\n--- Available Products ---");
        for (int i = 0; i < catalog.length; i++) {
            System.out.println((i + 1) + ". " + catalog[i] + " - Stock: " + stock[i]);
        }
    }

    public static void purchaseItem(int index, int qty) {
        if (index >= 0 && index < catalog.length) {
            if (stock[index] >= qty) {
                stock[index] -= qty;
                System.out.println("Successfully purchased " + qty + " units of " + catalog[index]);
            } else {
                System.out.println("Insufficient inventory status.");
            }
        } else {
            System.out.println("Invalid selection.");
        }
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        while (true) {
            System.out.println("\n=== Mini E-Store ===\n1. Display items\n2. Purchase\n3. Shutdown");
            System.out.print("Choice: ");
            int action = sc.nextInt();
            if (action == 3) break;
            
            if (action == 1) {
                viewCatalog();
            } else if (action == 2) {
                viewCatalog();
                System.out.print("Select item number: ");
                int itemNum = sc.nextInt() - 1;
                System.out.print("Quantity: ");
                int quantity = sc.nextInt();
                purchaseItem(itemNum, quantity);
            }
        }
        sc.close();
    }
}
