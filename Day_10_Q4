public class main{
    public static void main(String[] args){
        for(int i=65;i<=69;i++){
            for(int j=1;j<=5-i+64;j++){
                System.out.print(" ");
            }
            for(int j=65;j<=i;j++){
                System.out.print((char)j);
            }
            for(int j=i-1;j>=65;j--){
                System.out.print((char)j);
            }
            System.out.println();
        }
    }
}
