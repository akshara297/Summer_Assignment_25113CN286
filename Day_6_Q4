public class Power {
    public static double pow(double x, long n) {
        if(n ==0) return 1;
        if(n<0) return 1/pow(x,-n);
        return n%2 == 0? pow(x*x, n/2) : x*pow(x*x, n/2);
    }
    public static void main(String[] args){
        System.out.println(pow(2.0,10));
        System.out.println(pow(2.0,-2));
    }
}