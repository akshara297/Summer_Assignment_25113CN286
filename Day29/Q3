import java.util.Scanner;

public class StringOperationsSystem {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter a baseline string: ");
        String text = sc.nextLine();
        
        while (true) {
            System.out.println("\n--- String Operations ---\n1. Reverse\n2. Change to Upper case\n3. Get Length\n4. Exit");
            System.out.print("Choice: ");
            int choice = sc.nextInt();
            if (choice == 4) break;
            
            switch (choice) {
                case 1:
                    System.out.println("Reversed: " + new StringBuilder(text).reverse());
                    break;
                case 2:
                    System.out.println("Upper Case: " + text.toUpperCase());
                    break;
                case 3:
                    System.out.println("Length: " + text.length());
                    break;
            }
        }
        sc.close();
    }
}
