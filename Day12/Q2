public class Armstrong{
    public static int Armstrong(int num){
        int sum = 0;
        int temp = num;
        while(temp !=0){
            int digit = temp % 10;
            sum += Math.pow(digit,3);
            temp /= 10;
        }
        if(sum == num){
            return 1;
        }
        else{
            return 0;
        }
    }

    public static void main(String[] args){
        int num = 153;
        int result = Armstrong(num);
        System.out.println(result);
    }
}
